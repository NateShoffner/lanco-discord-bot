# Flask
DASHBOARD_SECRET_KEY=change-me-to-a-random-string

# Discord OAuth2 — create an app at https://discord.com/developers/applications
# Add http://localhost:5000/callback to the OAuth2 Redirects list
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5000/callback

# Database — must match the bot's .env
DB_TYPE=sqlite
SQLITE_DB=../data/lancobot.db

# MySQL (only if DB_TYPE=mysql)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=

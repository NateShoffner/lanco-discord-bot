# =========================
# Discord Bot Configuration
# =========================

# Discord bot token
DISCORD_TOKEN=
# Discord user ID of the bot owner
OWNER_ID=
# GitHub repository link
GITHUB_REPO=

# =========================
# Database Configuration
# =========================

# Database type: sqlite or mysql
DB_TYPE=sqlite

# SQLite settings
SQLITE_DB=data/lancobot.db

# MySQL settings (only required if DB_TYPE=mysql)
MYSQL_HOST=
MYSQL_PORT=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=

# =========================
# Database Backup Settings
# =========================

# Directory for database backups
DATABASE_BACKUP_DIRECTORY=data/backups
# Backup filename pattern
DATABASE_BACKUP_FILENAME=lancobot_backup_{}.db
# Backup interval in seconds (default: 86400 = 24 hours)
DATABASE_BACKUP_INTERVAL=86400
# Number of backups to retain
DATABASE_BACKUP_RETENTION=7

# =========================
# Bot Settings
# =========================

# Number of messages to cache
MESSAGE_CACHE_SIZE=1000
# Enable development mode (set automatically by poetry run dev)
DEV_MODE=false

# =========================
# Logging
# =========================

# Logtail logging token (optional)
LOGTAIL_TOKEN=

# Elastic APM error tracking (optional). Enabled only when SERVER_URL is set.
# APM Server URL (e.g. https://<id>.apm.<region>.cloud.es.io:443)
ELASTIC_APM_SERVER_URL=
# Auth: set one (token for Elastic Cloud, API key otherwise)
ELASTIC_APM_SECRET_TOKEN=
ELASTIC_APM_API_KEY=
# Service name in the APM UI (defaults to "lanco-bot")
ELASTIC_APM_SERVICE_NAME=lanco-bot

# Dev mode only: comma-separated list of cog names to show console log output for.
# All other cog loggers are suppressed on the console (still written to log file).
# Example: LOG_COGS=geoguesser,incidents
LOG_COGS=

# =========================
# Development
# =========================

# Comma-separated list of cog directory names to load exclusively.
# When set, only the listed cogs are loaded — all others are skipped.
# Useful for faster startup during development.
# Example: COG_WHITELIST=geoguesser
COG_WHITELIST=

# Comma-separated list of cog directory names to skip on startup. Ignored if COG_WHITELIST is set.
# Example: COG_BLACKLIST=honeybot,triviasniper
COG_BLACKLIST=

# =========================
# API Keys
# =========================

# Google Maps API key
GMAPS_API_KEY=

# OpenWeatherMap API key
OPENWEATHERMAP_API_KEY=
# OpenCage Geocoding API key
OPENCAGE_API_KEY=

# Spotify client ID
SPOTIFY_CLIENT_ID=
# Spotify client secret
SPOTIFY_SECRET=

# OpenAI API key
OPENAI_API_KEY=
# OpenAI Admin API key — requires api.usage.read scope (used by the tokenusage cog)
OPENAI_ADMIN_KEY=
# OpenAI project ID to scope usage queries to this project only
OPENAI_PROJECT_ID=
# Wolfram Alpha API key
WOLFRAM_ALPHA_API_KEY=
# VirusTotal API key
VIRUS_TOTAL_API_KEY=
# YouTube Data API key
YOUTUBE_API_KEY=
# NewsAPI key
NEWSAPI_API_KEY=

# =========================
# Third-party Integrations
# =========================

# Everbridge
EVERBRIDGE_USERNAME=
EVERBRIDGE_PASSWORD=

# Google Calendar API key
GOOGLE_CAL_API_KEY=

# Sightengine
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# Truth Social
TRUTH_SOCIAL_USERNAME=
TRUTH_SOCIAL_PASSWORD=
